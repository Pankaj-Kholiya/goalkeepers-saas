# Copy to .env (Prisma CLI reads .env) and .env.local (Next runtime).
# On Vercel, set these in Project Settings -> Environment Variables.

# -----------------------------------------------------------------------------
# Database - Postgres (managed: Neon / Supabase / Railway)
# -----------------------------------------------------------------------------
# DATABASE_URL = POOLED connection (runtime, serverless-safe).
#   Neon: the host with "-pooler" in it, append ?sslmode=require
#   e.g. postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/goalkeepers?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/goalkeepers?schema=public"

# DIRECT_URL = DIRECT/unpooled connection (migrations + db push).
#   Neon: the host WITHOUT "-pooler".
#   Locally you can point this at the same DB as DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/goalkeepers?schema=public"

# -----------------------------------------------------------------------------
# Tenancy
# -----------------------------------------------------------------------------
# Bare apex domain. Subdomains of this become tenant slugs.
#   dev:  localhost:3000   ->  acme.localhost:3000 = tenant "acme"
#   prod: goalkeepers.app  ->  acme.goalkeepers.app = tenant "acme"
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

# -----------------------------------------------------------------------------
# Billing (Razorpay) - set up at the end
# -----------------------------------------------------------------------------
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# Transactional email - Zoho ZeptoMail (invites, password resets)
# -----------------------------------------------------------------------------
# The "Send Mail" token from ZeptoMail (the value AFTER "Zoho-enczapikey ").
# ZEPTOMAIL_TOKEN=""
# A verified sender address on your ZeptoMail domain, + optional display name.
# EMAIL_FROM="noreply@yourschool.org"
# EMAIL_FROM_NAME="GoalKeepers"
# India ZeptoMail accounts use the .in data centre:
# ZEPTOMAIL_API_URL="https://api.zeptomail.in/v1.1/email"

# -----------------------------------------------------------------------------
# AI Chatbot module (optional) - one provider key enables live answers
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=""        # uses OPENAI_MODEL (default gpt-4o-mini)
# ANTHROPIC_API_KEY=""     # uses ANTHROPIC_MODEL (default claude-3-5-haiku-latest)
# Optional model overrides:
# OPENAI_MODEL="gpt-4o-mini"
# ANTHROPIC_MODEL="claude-3-5-haiku-latest"

# -----------------------------------------------------------------------------
# Platform support (super-admin notifications)
# -----------------------------------------------------------------------------
# Where a school's "activate the AI Chatbot" request is emailed (needs the
# email block above configured). Unset = the request is still recorded, it
# just isn't emailed to you.
# PLATFORM_SUPPORT_EMAIL="ops@yourcompany.com"

# -----------------------------------------------------------------------------
# Scheduled jobs - Vercel Cron
# -----------------------------------------------------------------------------
# Shared secret guarding /api/cron/* (e.g. weekly-challenge). Vercel Cron sends
# `Authorization: Bearer <CRON_SECRET>`. Unset = the cron endpoints refuse
# (fail closed), so set this in prod once cron is scheduled.
# CRON_SECRET=""

# =============================================================================
# Cross-app SSO - GoalKeepers as the OIDC provider (IdP)
# =============================================================================
# GoalKeepers signs staff into the add-ons (Prayaas Assessments, Website AI
# Chatbot, Social Media Studio) with RS256 id_tokens, so "Open Prayaas" /
# "Manage Knowledge Base" land already authenticated. Leave the key + clients
# unset and the provider reports "not configured": every /api/oidc/* route 503s
# and nothing else breaks - SSO is simply off.

# Stable issuer host that serves the OIDC endpoints, NO trailing slash. Must be
# reachable by the add-ons (use the apex, not a tenant subdomain).
# GK_OIDC_ISSUER="https://goalkeepers.org.in"

# RS256 private key, PKCS#8 PEM. Provide EITHER the PEM with literal \n escapes
# on one line, OR the base64 of the whole PEM file. Generate a 2048-bit key:
#   openssl genpkey -algorithm RSA -pkcs8 -out gk-oidc.key -pkeyopt rsa_keygen_bits:2048
#   one-line (escaped):  awk 'BEGIN{ORS="\\n"} {print}' gk-oidc.key
#   or base64:           base64 -w0 gk-oidc.key
# GK_OIDC_PRIVATE_KEY=""
# Key id published in JWKS (lets you rotate keys later). Default: gk-oidc-1.
# GK_OIDC_KID="gk-oidc-1"

# Optional GoalKeepers login URL that /api/oidc/authorize bounces to when there
# is no gk_session (it appends ?from=). Unset = the add-on gets login_required.
# GK_LOGIN_URL="https://goalkeepers.org.in/login"

# Session cookie domain so one gk_session spans every tenant subdomain AND the
# issuer host. REQUIRED for SSO in prod; leave UNSET in local dev (host-only).
# GK_COOKIE_DOMAIN=".goalkeepers.org.in"

# --- Registered clients: one block per add-on you connect --------------------
# *_REDIRECT_URIS is a comma-separated allow-list that must EXACTLY match the
# callback URL the add-on sends. Generate each secret with: openssl rand -hex 32
#
# Prayaas Assessments - Better Auth genericOAuth (providerId "goalkeepers"):
#   callback = <prayaas-host>/api/auth/oauth2/callback/goalkeepers
# GK_OIDC_CLIENT_PRAYAAS_ID="prayaas-assessments"
# GK_OIDC_CLIENT_PRAYAAS_SECRET=""
# GK_OIDC_CLIENT_PRAYAAS_REDIRECT_URIS="https://app.prayaassessments.com/api/auth/oauth2/callback/goalkeepers"
#
# Website AI Chatbot - small OIDC client:
#   callback = <chatbot-host>/api/sso/goalkeepers/callback  (its GOALKEEPERS_REDIRECT_URI)
# GK_OIDC_CLIENT_CHATBOT_ID="website-chatbot"
# GK_OIDC_CLIENT_CHATBOT_SECRET=""
# GK_OIDC_CLIENT_CHATBOT_REDIRECT_URIS="https://chatbot.prayaassessments.com/api/sso/goalkeepers/callback"
#
# Social Media Studio:
#   callback = <social-host>/api/sso/goalkeepers/callback
# GK_OIDC_CLIENT_SOCIAL_MEDIA_ID="social-media"
# GK_OIDC_CLIENT_SOCIAL_MEDIA_SECRET=""
# GK_OIDC_CLIENT_SOCIAL_MEDIA_REDIRECT_URIS="https://social.prayaassessments.com/api/sso/goalkeepers/callback"

# =============================================================================
# RLS - database-enforced tenant isolation (optional hardening, OFF by default)
# =============================================================================
# A Postgres backstop beneath the app-layer tenant scoping: even an app bug that
# forgot a tenant filter can't leak cross-tenant rows. The app-side wiring ships
# DORMANT. To turn it on, follow docs/RLS.md (create the non-owner `app_rls`
# role, run prisma/rls.sql in Neon), then set BOTH of these:
# DB_RLS_ENABLED="1"
# DATABASE_URL_RLS = POOLED connection string for the app_rls role, e.g.
# DATABASE_URL_RLS="postgresql://app_rls:PASS@ep-xxx-pooler.region.aws.neon.tech/goalkeepers?sslmode=require"
