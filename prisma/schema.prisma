// GoalKeepers SaaS - multi-tenant quiz platform for schools.
//
// Tenancy model: every domain row carries a `tenantId`. A school
// (Tenant) only ever sees its own rows. Isolation is enforced
// centrally by the Prisma client extension in src/lib/db.ts - feature
// code never hand-writes `where: { tenantId }`, so it can't be
// forgotten. Postgres is chosen so row-level security can be layered
// on as a database-enforced backstop (see docs/ARCHITECTURE.md).
//
// The platform super-admin (Editude) is a User with tenantId = null
// and role = SUPER_ADMIN; they use the UNSCOPED client to provision
// tenants + manage billing.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime: the POOLED connection string (PgBouncer). Serverless
  // functions open many short-lived connections; the pooler keeps
  // Postgres from running out. On Neon this is the "-pooler" host.
  url       = env("DATABASE_URL")
  // Migrations + introspection: the DIRECT (unpooled) connection.
  // Prisma migrate needs a real session, which transaction-mode
  // pooling breaks. On Neon this is the non-pooler host. For local
  // dev both can point at the same local Postgres.
  directUrl = env("DIRECT_URL")
}

// ===========================================================================
// Enums
// ===========================================================================

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
}

enum Role {
  SUPER_ADMIN // platform owner (Editude) - tenantId is null
  TENANT_ADMIN // school account owner
  TEACHER // authors questions, builds quiz events
  STUDENT // takes quizzes
}

enum QuestionType {
  MCQ
  MSQ
  SHORT
  LONG
  ASSERTION_REASONING
  CASE_BASED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuizMode {
  LIVE // host pushes questions in real time
  ASYNC // students attempt any time in a window
}

enum EventStatus {
  DRAFT
  SCHEDULED
  LIVE
  CLOSED
}

// ===========================================================================
// Tenancy + identity
// ===========================================================================

model Tenant {
  id           String       @id @default(cuid())
  // Subdomain handle: <slug>.goalkeepers.app. Lowercase, unique.
  slug         String       @unique
  name         String
  logoUrl      String?
  primaryColor String? // white-label theming, hex
  status       TenantStatus @default(TRIAL)
  trialEndsAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users        User[]
  questions    Question[]
  quizEvents   QuizEvent[]
  attempts     QuizAttempt[]
  sponsors     Sponsor[]
  subscription Subscription?
  modules      TenantModule[]
  weeklyChallenges        WeeklyChallenge[]
  weeklyChallengeAttempts WeeklyChallengeAttempt[]
  campaigns               Campaign[]
  campaignRecipients      CampaignRecipient[]
  feedback                Feedback[]
  notifications           Notification[]
  bookmarks               QuestionBookmark[]
  integrations            TenantIntegration[]
  referrals               Referral[]

  @@index([status])
}

model User {
  id           String   @id @default(cuid())
  // Null ONLY for SUPER_ADMIN (platform owner). Every tenant user has one.
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  name         String?
  role         Role     @default(STUDENT)
  passwordHash String?
  isActive     Boolean  @default(true)
  // Personal referral code (lazily generated) for the gamified
  // invite-a-classmate system. Globally unique.
  referralCode String?  @unique
  // Student's class/grade (e.g. "Class 10"). Drives weekly challenges +
  // class-targeted communications. Null for staff or when unset.
  classGrade   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  authoredQuestions Question[]    @relation("QuestionAuthor")
  attempts          QuizAttempt[]
  sessions          Session[]
  passwordResetTokens     PasswordResetToken[]
  weeklyChallengeAttempts WeeklyChallengeAttempt[]
  notifications           Notification[]
  bookmarks               QuestionBookmark[]

  // Email is unique WITHIN a tenant, not globally - two different
  // schools can each have a "principal@" user. The compound unique
  // also lets the same human exist under two tenants if ever needed.
  @@unique([tenantId, email])
  @@index([tenantId, role])
}

// DB-backed sessions. We use a custom credentials auth (not Better-Auth)
// because Better-Auth assumes globally-unique emails, which fights our
// per-tenant email uniqueness. The cookie holds a high-entropy random
// token; the row is the source of truth so sessions are revocable.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Password-reset tokens. Like Session, NOT tenant-scoped: a reset is looked
// up by its high-entropy token before any tenant context exists. Single-use
// (usedAt) + time-boxed (expiresAt). The cookie/URL carries only the token.
model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ===========================================================================
// Question bank (per-tenant) - shape lifted from Prayaas Question
// ===========================================================================

model Question {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type          QuestionType @default(MCQ)
  text          String
  // JSON: [{ id: "a", text: "..." }, ...]. Null for SHORT/LONG.
  options       String?
  // JSON: "a" (MCQ) | ["a","c"] (MSQ) | free text (SHORT). Null for LONG.
  correctAnswer String?
  modelAnswer   String?
  subject       String
  topic         String?
  chapter       String?
  // Optional class/grade tag. Weekly challenges pick per class; a null
  // classGrade means the question is eligible for any class.
  classGrade    String?
  difficulty    Difficulty   @default(MEDIUM)
  marks         Int          @default(1)
  imageUrl      String?
  // CASE_BASED only - JSON array of sub-parts.
  subParts      String?
  isActive      Boolean      @default(true)
  createdById   String?
  createdBy     User?        @relation("QuestionAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  bookmarks     QuestionBookmark[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tenantId, subject])
  @@index([tenantId, isActive, type])
  @@index([tenantId, classGrade])
}

// ===========================================================================
// Quiz events (the headline feature)
// ===========================================================================

model QuizEvent {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  description String?
  mode        QuizMode    @default(ASYNC)
  status      EventStatus @default(DRAFT)
  startsAt    DateTime?
  endsAt      DateTime?
  // JSON: { mode: "pinned", questionIds: [...] } OR
  //       { mode: "sampler", subject, count, difficultyMix }.
  selection   String
  // JSON: { shuffleQuestions, shuffleOptions, timeLimitSec, badgeTiers,
  //         leaderboardVisible }.
  settings    String
  // Optional sponsor whose branding rides along on this event.
  sponsorId   String?
  sponsor     Sponsor?    @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
  // LIVE mode (Wave 5): the host advances questions; -1 = lobby (not
  // started), 0..n = the question index currently open, livePhase is
  // LOBBY | QUESTION | REVEAL | ENDED. Unused by ASYNC events.
  currentQuestionIndex Int    @default(-1)
  livePhase            String @default("LOBBY")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  attempts QuizAttempt[]

  @@index([tenantId, status])
  @@index([tenantId, startsAt])
}

model QuizAttempt {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quizEventId  String
  quizEvent    QuizEvent @relation(fields: [quizEventId], references: [id], onDelete: Cascade)
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // JSON: { [questionId]: answerPayload }. Null until submitted.
  answers      String?
  score        Int       @default(0)
  correctCount Int       @default(0)
  badge        String?
  startedAt    DateTime  @default(now())
  submittedAt  DateTime?

  @@unique([quizEventId, userId])
  // Leaderboard query: filter by event, order score desc + earliest
  // submit wins ties. Indexed up front so it never filesorts.
  @@index([quizEventId, score(sort: Desc), submittedAt])
  @@index([tenantId])
}

// ===========================================================================
// Sponsors (per-tenant revenue feature - Part XI of the playbook)
// ===========================================================================

model Sponsor {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  logoUrl    String
  websiteUrl String?
  // JSON: { quiz: bool, leaderboard: bool, results: bool }.
  placement  String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  quizEvents QuizEvent[]

  @@index([tenantId, active])
}

// ===========================================================================
// Billing
// ===========================================================================

model Plan {
  id           String  @id @default(cuid())
  slug         String  @unique // free | pro | school-plus
  name         String
  priceMonthly Int // in paise / cents
  maxEvents    Int? // null = unlimited
  maxStudents  Int?
  // JSON array of feature keys this plan unlocks.
  features     String
  isActive     Boolean @default(true)

  subscriptions Subscription[]
}

model Subscription {
  id               String    @id @default(cuid())
  tenantId         String    @unique
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan      @relation(fields: [planId], references: [id])
  status           String    @default("trialing") // trialing | active | past_due | canceled
  currentPeriodEnd DateTime?
  razorpaySubId    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ===========================================================================
// Modules - GoalKeepers is a PLATFORM; each tenant (school) enables the
// modules it has bought: Prayaas (assessments / quiz events, the headline
// product), AI Chatbot, and more over time. Module DEFINITIONS (name,
// nav, icon, default) live in code at src/lib/modules.ts - this table is
// only the per-tenant on/off switch, flipped by the super-admin from the
// tenant detail page. A missing row means "use the module's default".
// ===========================================================================

model TenantModule {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleKey String // 'prayaas' | 'ai-chatbot' | ... (see src/lib/modules.ts)
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
}

// ===========================================================================
// Weekly Challenges (Prayaas module) - a short, recurring per-class quiz.
// Migrated from the Prayaas "GoalKeepers" section, now tenant-scoped. The 5
// question ids are pinned on the row at creation so later bank edits never
// change a live/closed challenge. See src/lib/weekly-challenge.ts.
// ===========================================================================

enum WeeklyChallengeBadge {
  LEGEND // all correct
  PERFORMER
  CHAMPION
  STARTER
}

model WeeklyChallenge {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classGrade  String
  weekKey     String // ISO week, e.g. "2026-W18"
  openedAt    DateTime
  closedAt    DateTime
  // JSON array of Question ids, pinned at creation (immutable set).
  questionIds String
  createdAt   DateTime @default(now())

  attempts WeeklyChallengeAttempt[]

  @@unique([tenantId, classGrade, weekKey])
  @@index([tenantId, openedAt])
}

model WeeklyChallengeAttempt {
  id           String                @id @default(cuid())
  tenantId     String
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  challengeId  String
  challenge    WeeklyChallenge       @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId       String
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  // JSON { [questionId]: '"a"' | '["a","c"]' }. Null until submitted.
  answers      String?
  correctCount Int                   @default(0)
  badge        WeeklyChallengeBadge?
  startedAt    DateTime              @default(now())
  submittedAt  DateTime?

  @@unique([challengeId, userId])
  @@index([tenantId])
  // Leaderboard: most-correct first, earliest submit breaks ties.
  @@index([challengeId, correctCount(sort: Desc), submittedAt])
}

// ===========================================================================
// Communications (new module) - bulk email campaigns to a school's students.
// ===========================================================================

model Campaign {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  subject     String
  body        String
  // JSON: { kind: 'all' | 'class', classGrade?: string }
  audience    String
  status      String   @default("DRAFT") // DRAFT | SENDING | SENT | FAILED
  sentCount   Int      @default(0)
  failedCount Int      @default(0)
  createdAt   DateTime @default(now())

  recipients CampaignRecipient[]

  @@index([tenantId, createdAt])
}

model CampaignRecipient {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  userId     String
  email      String
  status     String   @default("PENDING") // PENDING | SENT | FAILED
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([campaignId, status])
}

// ===========================================================================
// Support / feedback - messages sent by schools + students from the
// in-app Help & Support page. Created SCOPED to the sender's tenant; the
// platform super-admin reads them ALL (unscoped) from the /admin Support
// inbox. userEmail / userName / role are snapshotted so the inbox reads
// cleanly even if the sender is later removed.
// ===========================================================================

model Feedback {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  userEmail String
  userName  String?
  role      Role
  kind      String   @default("FEEDBACK") // FEEDBACK | PROBLEM
  message   String
  status    String   @default("NEW") // NEW | SEEN | RESOLVED
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([status, createdAt])
}

// ===========================================================================
// Notifications - per-user account/activity events (quiz results, weekly
// challenge results, ...). Surfaced by the header bell + /dashboard/
// notifications. Tenant-scoped.
// ===========================================================================

model Notification {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // QUIZ_RESULT | CHALLENGE_RESULT | INFO
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tenantId, userId, createdAt])
  @@index([userId, readAt])
}

// ===========================================================================
// Saved questions - a student stars a question for later review. Tenant-
// scoped; unique per (user, question).
// ===========================================================================

model QuestionBookmark {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, questionId])
  @@index([tenantId, userId, createdAt])
}

// ===========================================================================
// Integrations - external "Prayaas product" addons a school connects:
// Prayaas Assessments (enable/disable + staff SSO) and the Website AI Chatbot
// (request -> super-admin approval -> install script + KB link). Distinct from
// internal Modules (TenantModule), which gate GoalKeepers' own features.
// Tenant-scoped; the super-admin reads requests cross-tenant via dbUnscoped.
// ===========================================================================

model TenantIntegration {
  id                 String    @id @default(cuid())
  tenantId           String
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product            String // 'prayaas-assessments' | 'website-chatbot'
  // prayaas-assessments: INACTIVE | ACTIVE
  // website-chatbot:     NOT_ACTIVATED | PENDING | ACTIVE
  status             String    @default("NOT_ACTIVATED")
  websiteUrl         String? // school's website (chatbot request)
  externalTenantSlug String? // mapped tenant/org in the addon app
  externalBaseUrl    String? // e.g. https://chatbot.prayaassessments.com
  widgetVersion      String? // widget.js ?v= cache-buster
  manageUrl          String? // deep target for "Manage Knowledge Base"
  requestedByUserId  String?
  requestedAt        DateTime?
  approvedAt         DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([tenantId, product])
  @@index([status])
}

// ===========================================================================
// Referrals - gamified "invite a classmate" system. A student shares their
// code; when a classmate joins in via that code, a Referral row links them.
// One referral per referee (a student can only be referred once). Tenant-
// scoped, so referrals never cross schools.
// ===========================================================================

model Referral {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  referrerId String // the inviting student
  refereeId  String // the invited student (credited once, ever)
  createdAt  DateTime @default(now())

  @@unique([refereeId])
  @@index([tenantId, referrerId])
}
